{
  "_comment": "raw/ 文档来源清单。由 scripts/sync_docs.py 读取，执行下载与更新。",
  "_usage": {
    "sync all": "python scripts/sync_docs.py",
    "sync one": "python scripts/sync_docs.py <name>",
    "update ref": "python scripts/sync_docs.py --update <name> <ref>",
    "list status": "python scripts/sync_docs.py --list"
  },
  "_types": {
    "github-dir": "下载 GitHub 仓库中某个子目录（通过 GitHub API + zip）",
    "github-repo": "下载整个 GitHub 仓库（通过 zip archive）",
    "url": "直接下载单个文件（raw URL）"
  },
  "sources": [
    {
      "_comment": "只需要 neovim 仓库的 runtime/doc 目录",
      "name": "neovim-docs",
