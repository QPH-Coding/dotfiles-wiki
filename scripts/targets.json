{
  "_comment": "部署目标配置文件。每个工具对应 dotfiles/<tool>/ 目录，部署到系统指定路径。",
  "_usage": "由 scripts/deploy.py 读取，执行: python scripts/deploy.py <tool> [--dry-run]",
  "targets": {
    "nvim": {
      "windows": "%LOCALAPPDATA%\\nvim",
      "unix": "~/.config/nvim"
    },
    "wezterm": {
      "windows": "%USERPROFILE%\\.config\\wezterm",
      "unix": "~/.config/wezterm"
    },
    "alacritty": {
      "windows": "%APPDATA%\\alacritty",
      "unix": "~/.config/alacritty"
    },
    "zsh": {
      "unix": "~"
    },
    "bash": {
      "unix": "~"
    },
    "git": {
      "windows": "%USERPROFILE%",
      "unix": "~"
    },
    "tmux": {
      "unix": "~"
    }
  }
}
